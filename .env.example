# Copy to .env and fill in real values. Never commit .env.

# --- Postgres (one instance, two databases: `zitadel` + `entitlement`) ---
POSTGRES_USER=pg
POSTGRES_PASSWORD=changeme

# --- Zitadel ---
# Must be exactly 32 characters. Generate with:
#   tr -dc A-Za-z0-9 </dev/urandom | head -c 32
# Cannot be changed after first boot without losing access to encrypted data.
ZITADEL_MASTERKEY=changemechangemechangemechangeme
# Domain Zitadel is exposed on (no scheme). Use localhost for local dev.
ZITADEL_EXTERNALDOMAIN=localhost
# Behind Cloudflare/HTTPS set true + 443 + TLSMODE=external. Local HTTP: false + 8080 + disabled.
ZITADEL_EXTERNALSECURE=false
ZITADEL_EXTERNALPORT=8080
ZITADEL_TLSMODE=disabled

# --- Entitlement service (see entitlement/src/config/env.ts) ---
# host dev: localhost | docker compose: db (override ใน compose ให้อยู่แล้ว)
DATABASE_URL=postgres://pg:changeme@localhost:5432/entitlement
PORT=3000
ZITADEL_ISSUER=http://localhost:8080
ZITADEL_JWKS_URL=http://localhost:8080/oauth/v2/keys
ZITADEL_AUDIENCE=changeme
ZITADEL_MGMT_URL=http://localhost:8080
ZITADEL_MGMT_TOKEN=changeme
CLAIMS_SHARED_SECRET=changeme
# Zitadel Actions v2 target signingKey (shown once by CreateTarget) — see zitadel/actions/token-claims.md §3
ZITADEL_ACTIONS_SIGNING_KEY=changeme
